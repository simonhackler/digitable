{
	"name": "svg-table",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"svgedit/packages/svgcanvas"
	],
	"scripts": {
		"dev": "concurrently \"bun run --filter=@svg-table/app dev\" \"bun run --filter=boardgame-server start\"",
		"dev:app": "bun run --filter=@svg-table/app dev",
		"dev:svg": "concurrently \"bun run dev:svgcanvas\" \"cd svgedit && bun x vite dev --host --port 8001\" \"bun run --filter=@svg-table/app dev\"",
		"dev:svgcanvas": "cd svgedit/packages/svgcanvas && bun x vite build --watch",
		"dev:studio": "bun run --filter=studio dev",
		"dev:server": "bun run --filter=boardgame-server start",
		"auth:generate": "bun --env-file=.env run --filter=@svg-table/db auth:generate",
		"db:generate": "bun --env-file=.env run --filter=@svg-table/db db:generate",
		"db:migrate": "bun --env-file=.env run --filter=@svg-table/db db:migrate",
		"db:studio": "bun --env-file=.env run --filter=@svg-table/db db:studio",
		"build": "bun run --filter=@svg-table/app build",
		"preview": "bun --env-file=.env run --filter=@svg-table/app preview",
		"check": "bun run --filter=@svg-table/app check",
		"check:watch": "bun run --filter=@svg-table/app check:watch",
		"format": "bun run --filter=@svg-table/app format",
		"lint": "bun run --filter=@svg-table/app lint",
		"test": "bun --env-file=.env run --filter=@svg-table/app test",
		"test:e2e": "bun --env-file=.env run --filter=@svg-table/app test:e2e",
		"storybook": "bun run --filter=@svg-table/app storybook",
		"build-storybook": "bun run --filter=@svg-table/app build-storybook"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/debug": "^4.1.13",
		"@types/node": "^24.12.2",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.4",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"studio": "workspace:*",
		"super-sitemap": "^1.0.7",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0"
	},
	"dependencies": {
		"@pixi/devtools": "^2.0.1",
		"@pixi/layout": "^3.2.0",
		"feed": "^5.2.0",
		"pixi-viewport": "^6.0.3",
		"pixi.js": "8.17.1",
		"studio": "workspace:*",
		"svelte-meta-tags": "^4.5.2"
	}
}
