		"jspreadsheet-ce": "^5.0.4",
		"jsuites": "^5.13.4",
		"pagedjs": "^0.4.3",
		"papaparse": "^5.5.3",
		"pixi-viewport": "^6.0.3",
		"pixi.js": "8.17.1",
		"runed": "^0.37.0",
		"svelte-lexical": "workspace:*",
		"svelte-sonner": "^1.0.7",
		"wellcrafted": "^0.35.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.3",
