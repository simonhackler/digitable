{
	"name": "@svg-table/app",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run --cwd ../.. build:svelte-lexical && vite dev",
		"build": "bun run --cwd ../.. build:svelte-lexical && vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "bun run --cwd ../.. build:svelte-lexical && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun run --cwd ../.. build:svelte-lexical && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint . --max-warnings 0",
		"test:e2e": "playwright test",
		"test": "npm run test:e2e",
		"traceway:sourcemaps": "bun --env-file=../../.env traceway-sourcemaps --url \"${TRACEWAY_URL:-http://localhost:18081}\" --version \"${PUBLIC_APP_VERSION:-dev}\" --directory ./build/client",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1045.0",
