		"@storybook/addon-vitest": "^10.1.4",
		"@storybook/sveltekit": "^10.1.4",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@tanstack/table-core": "^8.21.3",
