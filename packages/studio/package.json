		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.17",
		"@tracewayapp/sourcemap-upload": "^1.1.0",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"formsnap": "^2.0.1",
		"mdsvex": "^0.12.6",
		"super-sitemap": "^1.0.7",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
