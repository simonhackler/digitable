	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"traceway:sourcemaps": "bun --env-file=../../.env traceway-sourcemaps --url \"${TRACEWAY_URL:-http://localhost:18081}\" --version \"${PUBLIC_APP_VERSION:-dev}\" --directory ./build/client"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.0",
